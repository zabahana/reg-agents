# ==========================================================================
# reg-agents environment configuration
# Copy to .env and fill in.  NOTHING here is secret by default; the .env
# file itself is gitignored.
# ==========================================================================

# --- LLM provider: "openai" for local dev, "nim" for the NVIDIA demo -------
# NVIDIA NIM exposes an OpenAI-compatible API, so switching providers is just
# a base_url + key + model change. This is a core talking point in the demo.
LLM_PROVIDER=openai

# --- OpenAI (local dev on your Mac) ---------------------------------------
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- NVIDIA NIM (demo / GCP GPU) ------------------------------------------
# Hosted catalog: https://integrate.api.nvidia.com/v1 (get a key at build.nvidia.com)
# Self-hosted on GKE GPU: http://nim-llm.reg-agents.svc.cluster.local:8000/v1
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=nvapi-your-key-here
NIM_MODEL=meta/llama-3.1-8b-instruct

# --- Embeddings: "openai" or "nemo" (NVIDIA NeMo Retriever) ----------------
EMBEDDING_PROVIDER=openai
NEMO_EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
NEMO_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# --- Vector store: "faiss" (local) or "milvus" (GPU / cuVS on GKE) ---------
VECTOR_BACKEND=faiss
MILVUS_URI=http://milvus.reg-agents.svc.cluster.local:19530

# --- Fraud model serving: Triton URL. Empty => local heuristic fallback ----
TRITON_URL=

# --- A2A agent service URLs (docker-compose / k8s service DNS) -------------
RETRIEVER_AGENT_URL=http://localhost:8101
VALIDATION_AGENT_URL=http://localhost:8102
FRAUD_AGENT_URL=http://localhost:8103
REPORT_AGENT_URL=http://localhost:8104
# Model-development lifecycle (three lines of defense)
DEVELOPER_AGENT_URL=http://localhost:8105
VALIDATOR_AGENT_URL=http://localhost:8106
AUDIT_AGENT_URL=http://localhost:8107
LIFECYCLE_ORCHESTRATOR_URL=http://localhost:8108
COMPLAINT_AGENT_URL=http://localhost:8110

# --- MCP tool server URLs (SSE transport) ----------------------------------
REGULATIONS_MCP_URL=http://localhost:9101/sse
MODEL_REGISTRY_MCP_URL=http://localhost:9102/sse
FRAUD_MCP_URL=http://localhost:9103/sse
MODELING_MCP_URL=http://localhost:9104/sse
COMPLAINT_MCP_URL=http://localhost:9105/sse
