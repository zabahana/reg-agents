{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "title": "reg-agents \u2014 agents & Triton",
  "uid": "reg-agents-overview",
  "tags": [
    "reg-agents",
    "nvidia",
    "triton"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "app",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(http_requests_total, app)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "A2A agents (FastAPI)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Request rate by agent (req/s)",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (app) (rate(http_requests_total{app=~\"$app\"}[5m]))",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 request latency by agent",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "histogram_quantile(0.95, sum by (app, le) (rate(http_request_duration_seconds_bucket{app=~\"$app\"}[5m])))",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx error rate by agent",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (app) (rate(http_requests_total{app=~\"$app\",status=~\"5..|5xx\"}[5m]))",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Requests in last 5m (all agents)",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum(increase(http_requests_total{app=~\"$app\"}[5m]))",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "type": "row",
      "title": "Triton Inference Server (fraud model)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      }
    },
    {
      "type": "timeseries",
      "title": "Triton inference success rate (infer/s)",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (model) (rate(nv_inference_request_success[5m]))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Triton avg compute latency per inference",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "\u00b5s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (model) (rate(nv_inference_compute_infer_duration_us[5m])) / clamp_min(sum by (model) (rate(nv_inference_request_success[5m])), 1)",
          "legendFormat": "compute {{model}}"
        },
        {
          "datasource": "${datasource}",
          "expr": "sum by (model) (rate(nv_inference_queue_duration_us[5m])) / clamp_min(sum by (model) (rate(nv_inference_request_success[5m])), 1)",
          "legendFormat": "queue {{model}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU utilization (requires DCGM exporter)",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "avg by (gpu, Hostname) (DCGM_FI_DEV_GPU_UTIL)",
          "legendFormat": "gpu {{gpu}} {{Hostname}}"
        }
      ]
    }
  ]
}